ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
SECRET_KEY=changeme-generate-random-32-chars
RESUMES_DIR=resumes
SCREENSHOTS_DIR=screenshots
SESSIONS_DIR=sessions

# ── Browser ───────────────────────────────────────────────────────────────────
# false = show browser window (dev/debug), true = run silently (server/prod)
BROWSER_HEADLESS=false
# chrome = use real Chrome binary (real TLS/WebGL fingerprint); empty = Chromium
BROWSER_CHANNEL=chrome
MAX_BROWSER_INSTANCES=1

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use * only when allow_credentials is NOT needed (public read-only APIs).
# For the frontend team, add their deployed URL here.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# ── Outlook / Microsoft Graph (email verification) ────────────────────────────
# Register a free Azure app at https://portal.azure.com → App registrations
# then run: python scripts/setup_outlook_auth.py
OUTLOOK_CLIENT_ID=e732c92e-9140-46a2-a1ef-bb0ea9add4d7
OUTLOOK_TENANT_ID=common
OUTLOOK_REDIRECT_URI=http://localhost:8001/api/outlook/auth/callback
# ── 2captcha (CAPTCHA solving) ────────────────────────────────────────────────
# Get API key at https://2captcha.com
TWOCAPTCHA_API_KEY=
